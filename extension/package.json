{
  "name": "dont-be-a-viber",
  "displayName": "Don't Be a Viber",
  "description": "Don't vibe. Speed. One sentence in, at most one logical unit of code out — via your own Claude Code install. The thinking stays yours.",
  "version": "0.5.1",
  "publisher": "Phiality",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PhialsBasement/DoNotBeAViber.git"
  },
  "bugs": {
    "url": "https://github.com/PhialsBasement/DoNotBeAViber/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Programming Languages"
  ],
  "keywords": [
    "claude",
    "learning",
    "education",
    "natural language",
    "anti-vibe-coding"
  ],
  "icon": "icon.png",
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nlv",
          "title": "Don't Be a Viber",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "nlv": [
        {
          "type": "webview",
          "id": "nlv.settingsView",
          "name": "Settings"
        }
      ]
    },
    "commands": [
      {
        "command": "nlv.translateLine",
        "title": "NLV: Translate Current Line"
      },
      {
        "command": "nlv.ask",
        "title": "NLV: Ask a Conceptual Question"
      },
      {
        "command": "nlv.restartSession",
        "title": "NLV: Restart Claude Session"
      },
      {
        "command": "nlv.showLog",
        "title": "NLV: Show Learning Log"
      }
    ],
    "keybindings": [
      {
        "command": "nlv.translateLine",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "nlv.ask",
        "key": "ctrl+alt+q",
        "when": "editorTextFocus"
      },
      {
        "command": "nlv.accept",
        "key": "enter",
        "when": "nlv.suggestionVisible && inlineSuggestionVisible && editorTextFocus && !suggestWidgetVisible"
      },
      {
        "command": "nlv.dismiss",
        "key": "escape",
        "when": "nlv.suggestionVisible && editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Don't Be a Viber",
      "properties": {
        "nlv.model": {
          "type": "string",
          "default": "sonnet",
          "description": "Claude model alias for the warm session."
        },
        "nlv.effort": {
          "type": "string",
          "default": "low",
          "enum": ["low", "medium", "high", "xhigh", "max"],
          "description": "Effort level. 'low' measured fastest with no quality loss. Supported levels vary per model."
        },
        "nlv.sentenceHandling": {
          "type": "string",
          "default": "comment",
          "enum": ["comment", "strip"],
          "description": "On accept: keep the sentence as a comment above the code, or strip it."
        },
        "nlv.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python interpreter used to run the backend daemon."
        },
        "nlv.backendPath": {
          "type": "string",
          "default": "",
          "description": "Path to backend/server.py. Empty = ../backend/server.py relative to the extension folder (works when running from the repo)."
        },
        "nlv.maxLines": {
          "type": "number",
          "default": 10,
          "description": "Over-scope guard: refuse generations longer than this many lines."
        },
        "nlv.session.idleMinutes": {
          "type": "number",
          "default": 15,
          "description": "Kill the warm Claude session after this many idle minutes."
        }
      }
    }
  }
}
